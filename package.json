{
  "name": "echosync",
  "private": true,
  "version": "0.1.0",
  "description": "AI 同声传译助手工作区。",
  "scripts": {
    "dev:web": "npm --prefix apps/web run dev",
    "dev:desktop": "npm --prefix apps/desktop run dev",
    "build:wasapi-sidecar": "cargo build --manifest-path apps/wasapi-sidecar/Cargo.toml --release",
    "build:desktop": "npm --prefix apps/desktop run build",
    "test:desktop": "npm --prefix apps/desktop test",
    "typecheck:desktop": "npm --prefix apps/desktop run typecheck",
    "lint:web": "npm --prefix apps/web run typecheck",
    "typecheck:web": "npm --prefix apps/web run typecheck",
    "test:agent": "cd apps/agent && python -m pytest",
    "demo:agent": "cd apps/agent && python -m echosync_agent.main"
  },
  "engines": {
    "node": ">=20.19.0 <25",
    "python": ">=3.11"
  }
}
