# LiveKit 实时传输（后续可选，不是当前本地 MVP 主链路）
LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# 供应商选择
# mock 只适合事件链路演示；真实 PCM 音频请改为 funasr、voxtral 或 deepgram。
ECHOSYNC_ASR_PROVIDER=mock
ECHOSYNC_TRANSLATOR_PROVIDER=mock
ECHOSYNC_TTS_PROVIDER=disabled
ECHOSYNC_TARGET_LANG=zh-CN

# 术语表
ECHOSYNC_GLOSSARY_ENABLED=true
ECHOSYNC_GLOSSARY_DOMAIN=default
ECHOSYNC_GLOSSARY_TERMS_DIR=

# FunASR 本地流式识别
FUNASR_MODEL=paraformer-zh-streaming
FUNASR_DEVICE=auto
FUNASR_CHUNK_MS=600
# FunASR endpoint VAD。MVP 默认关闭；需要实验 Silero soft endpoint 时再打开。
# 关闭时仍有 hard timeout 兜底，避免连续语音无限延迟。
FUNASR_VAD_ENABLED=false
FUNASR_VAD_SILENCE_MS=300
FUNASR_VAD_ACTIVATION_THRESHOLD=0.5
ECHOSYNC_ASR_SERVER_PORT=8765

# Voxtral Realtime 云端流式识别
MISTRAL_API_KEY=
VOXTRAL_MODEL=voxtral-mini-transcribe-realtime-2602
VOXTRAL_TARGET_DELAY_MS=1000

# Deepgram Streaming Speech-to-Text 云端流式识别
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=en
DEEPGRAM_ENDPOINTING_MS=300

# 阿里云百炼 Qwen 实时音频模型
# ECHOSYNC_ASR_PROVIDER=qwen-asr：只做实时 ASR，后续仍走 DeepSeek/DeepL 翻译。
# ECHOSYNC_TRANSLATOR_PROVIDER=qwen-livetranslate：端到端语音翻译，源文默认由 Qwen ASR 回填。
DASHSCOPE_API_KEY=
QWEN_REALTIME_BASE_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
QWEN_ASR_MODEL=qwen3-asr-flash-realtime-2026-02-10
QWEN_ASR_LANGUAGE=auto
QWEN_ASR_VAD_SILENCE_MS=800
QWEN_LIVETRANSLATE_MODEL=qwen3.5-livetranslate-flash-realtime
QWEN_LIVETRANSLATE_SOURCE_LANG=auto
QWEN_LIVETRANSLATE_OUTPUT_AUDIO=false
QWEN_LIVETRANSLATE_SOURCE_BACKFILL=true

# 兼容 OpenAI API 的翻译服务，例如 DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# 可选慢速语义修复。默认关闭；开启后只在 committed 字幕后后台修复，不阻塞实时翻译。
ECHOSYNC_TRANSLATION_REPAIR_PROVIDER=disabled
ECHOSYNC_TRANSLATION_REPAIR_MODEL=deepseek-v4-flash
ECHOSYNC_TRANSLATION_REPAIR_TIMEOUT_MS=1500
ECHOSYNC_TRANSLATION_REPAIR_MAX_CONCURRENCY=1
ECHOSYNC_TRANSLATION_REPAIR_MODE=suspect_only

# DeepL 官方翻译 API（批量请求/响应式，不支持流式）
DEEPL_API_KEY=
DEEPL_BASE_URL=https://api-free.deepl.com
DEEPL_MODEL_TYPE=latency_optimized

# 会议记录 AI 摘要默认复用上面的 DeepSeek/OpenAI-compatible 配置。
# 如需给复盘摘要单独指定更便宜或更强的模型，可覆盖以下变量。
ECHOSYNC_SESSION_SUMMARY_API_KEY=
ECHOSYNC_SESSION_SUMMARY_BASE_URL=
ECHOSYNC_SESSION_SUMMARY_MODEL=

# 可选 TTS
# disabled / edge-tts / elevenlabs
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural
# 同传播报默认略快，降低译文语音追不上原声的概率。
EDGE_TTS_RATE=+15%
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# 同传优先低延迟；如更重视长文本质量，可改为 eleven_multilingual_v2。
ELEVENLABS_MODEL=eleven_flash_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_SPEED=1.15
# 同传语音尽量平稳：高 stability 降低情绪起伏，style=0 不放大表演风格，关闭 speaker boost 降低额外计算。
ELEVENLABS_STABILITY=0.85
ELEVENLABS_SIMILARITY_BOOST=0.75
ELEVENLABS_STYLE=0.0
ELEVENLABS_USE_SPEAKER_BOOST=false
# 逗号/顿号/分号这类停顿会优先切成 TTS 小句，长度和句号只做兜底。
ECHOSYNC_TTS_UTTERANCE_MAX_CHARS=42
ECHOSYNC_TTS_UTTERANCE_MIN_CHARS=8
# TTS 小句预合成并发数：先占位锁定顺序，再提前准备后句音频，减少连续口播空档。
ECHOSYNC_TTS_PREFETCH_CONCURRENCY=2
# 兼容旧 ElevenLabs stream 参数；官方已标记 deprecated，留空表示使用默认值。
ELEVENLABS_OPTIMIZE_STREAMING_LATENCY=
