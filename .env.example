# LiveKit realtime transport
LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Provider selection
ECHOSYNC_ASR_PROVIDER=mock
ECHOSYNC_TRANSLATOR_PROVIDER=mock
ECHOSYNC_TTS_PROVIDER=disabled
ECHOSYNC_TARGET_LANG=zh-CN

# FunASR streaming service
FUNASR_WS_URL=ws://127.0.0.1:10095

# OpenAI-compatible translator, e.g. DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Optional TTS
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural
